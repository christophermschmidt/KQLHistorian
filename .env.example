# Fabric / Kusto resource identifiers used by scripts/
# Copy this file to .env and fill in real values, or set these as environment variables.
# .env is git-ignored.

KUSTO_CLUSTER_URI=https://<eventhouse>.<region>.kusto.fabric.microsoft.com
KUSTO_DATABASE=<kql-database-name>
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_KQL_DB_ID=00000000-0000-0000-0000-000000000000
FABRIC_DASHBOARD_ID=00000000-0000-0000-0000-000000000000
